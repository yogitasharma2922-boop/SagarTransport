# Environment Variables Template
# Copy this file to .env and fill in your actual values

# ============================
# Server Configuration
# ============================
PORT=3000
LOCAL_MODE=0
JWT_SECRET=change_this_secret_for_production

# ============================
# Database Configuration
# ============================
# Format: postgresql://username:password@hostname:port/database
# Example: postgresql://user:pass@localhost:5432/sagartransport
DATABASE_URL=

# ============================
# Cloudflare R2 Configuration
# ============================
# Your Cloudflare Account ID (find in R2 dashboard)
CLOUDFLARE_ACCOUNT_ID=

# R2 API Token credentials
# Generate these in Cloudflare Dashboard > R2 > Settings > API Tokens
CLOUDFLARE_ACCESS_KEY_ID=

# IMPORTANT: Keep this secret! Never commit to git
CLOUDFLARE_ACCESS_KEY_SECRET=

# Your R2 bucket name
CLOUDFLARE_R2_BUCKET_NAME=

# (Optional) Custom domain for image URLs
# Leave empty to use default R2 URL format: https://bucket-name.account-id.r2.cloudflarestorage.com
# Format: https://images.yourdomain.com
CLOUDFLARE_R2_PUBLIC_URL=

# ============================
# Google Drive Configuration (Optional)
# ============================
# Only needed if not using Cloudflare R2 for storage

# Enable OAuth for Google Drive
USE_OAUTH=0

# Google OAuth credentials (if USE_OAUTH=1)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

# Google Service Account JSON path or environment variable
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
# GOOGLE_SERVICE_ACCOUNT_PATH=/path/to/service-account.json

# Google Drive root folder ID (folder where images are organized)
DRIVE_ROOT_FOLDER_ID=

# ============================
# Quick Start
# ============================
# 1. Set DATABASE_URL if using PostgreSQL
# 2. Set all CLOUDFLARE_* variables if using R2
# 3. Optionally set GOOGLE_* variables as fallback
# 4. Keep JWT_SECRET and CLOUDFLARE_ACCESS_KEY_SECRET secure
# 5. Run: npm install && npm start
