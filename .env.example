# Environment Variables Template
# Copy this file to .env and fill in your actual values

# ============================
# Server Configuration
# ============================
PORT=3000
LOCAL_MODE=0
JWT_SECRET=change_this_secret_for_production

# ============================
# Database Configuration
# ============================
# Format: postgresql://username:password@hostname:port/database
# Example: postgresql://user:pass@localhost:5432/sagartransport
DATABASE_URL=

# ============================
# Cloudflare R2 Configuration
# ============================
# Your Cloudflare Account ID (find in R2 dashboard)
CLOUDFLARE_ACCOUNT_ID=

# R2 API Token credentials
# Generate these in Cloudflare Dashboard > R2 > Settings > API Tokens
CLOUDFLARE_ACCESS_KEY_ID=

# IMPORTANT: Keep this secret! Never commit to git
CLOUDFLARE_ACCESS_KEY_SECRET=

# Your R2 bucket name
CLOUDFLARE_R2_BUCKET_NAME=

# (Optional) Custom domain for image URLs
# Leave empty to use default R2 URL format: https://bucket-name.account-id.r2.cloudflarestorage.com
# Format: https://images.yourdomain.com
CLOUDFLARE_R2_PUBLIC_URL=

# ============================
# Quick Start
# ============================
# 1. Set DATABASE_URL (required for production)
# 2. Set all CLOUDFLARE_* variables (required)
# 3. Keep JWT_SECRET and CLOUDFLARE_ACCESS_KEY_SECRET secure
# 4. Run: npm install && npm start
